      "id": "node-06-scrape",
      "name": "Scrape Website",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [880, 180],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Carry forward the original sheet row + add cleaned page text (per item)\nconst out = [];\nfor (let i = 0; i < $input.all().length; i++) {\n  const source = $('Has Website?').itemMatching(i).json;\n  const raw = $input.all()[i].json;\n  const html = raw.body || raw.html || raw.content || '';\n  const text = html\n    .replace(/<script[\\s\\S]*?<\\/script>/gi, '')\n    .replace(/<style[\\s\\S]*?<\\/style>/gi, '')\n    .replace(/<[^>]+>/g, ' ')\n    .replace(/&nbsp;/g, ' ')\n    .replace(/&amp;/g, '&')\n    .replace(/&lt;/g, '<')\n    .replace(/&gt;/g, '>')\n    .replace(/\\s+/g, ' ')\n    .trim()\n    .substring(0, 8000);\n  out.push({ json: { ...source, pageText: text } });\n}\nreturn out;"
      },
      "id": "node-07-striphtml",
      "name": "Strip HTML",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1100, 180]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"model\": \"gpt-4o\", \"max_tokens\": 10, \"temperature\": 0, \"messages\": [ { \"role\": \"system\", \"content\": \"# Role\\nLead Data Specialist\\n\\n# Task\\nIdentify if the following text contains a real business entity or practitioner. Output ONLY \\\"TRUE\\\" or \\\"FALSE\\\".\\n\\n# The \\\"Gold Standard\\\" (TRUE) - PRIORITY 1\\nIf you find ANY of the following, you MUST output TRUE. This overrides any \\\"junk\\\" or \\\"cookie\\\" text found elsewhere:\\n1. Professional Names: (e.g., Ραφτοπούλου Λία, Παναγιώτης Σκαφιδάς, Βερονίκη Σώλου).\\n2. Specific Titles: (e.g., Ψυχοθεραπευτής, Ψυχολόγος, Συμβουλευτική, Λακανική Ψυχανάλυση, Γιατρός).\\n3. Contact Details: Any Greek phone starting with 2, 69, or +30, or a specific Greek street address (e.g., Ηπείρου 11, Δέσπως Σέχου).\\n\\n# The \\\"Junk Standard\\\" (FALSE) - PRIORITY 2\\nONLY output FALSE if the text is EXCLUSIVELY one of these and contains NO specific practitioner name:\\n1. A raw server error (403 Forbidden / 404 Not Found).\\n2. A site-wide menu with generic categories (e.g., \\\"Home\\\", \\\"Contact\\\", \\\"Doctors\\\") but NO specific individual listed.\\n3. A login/signup wall that does not mention a specific professional's profile.\\n\\n# Strategic Instruction\\nIgnore all sections about \\\"Cookies,\\\" \\\"GDPR,\\\" or \\\"Privacy.\\\" The text may be from a directory (like Doctoranytime). Even if there is \\\"Login\\\" or \\\"Register\\\" text, if a specific doctor's name and bio/reviews appear in the noise, the answer is TRUE.\" }, { \"role\": \"user\", \"content\": $json.pageText } ] } }}",
        "options": {
          "batching": {
            "batch": {
              "batchSize": 1,
              "batchInterval": 500
            }
          }
        }
      },
      "id": "node-08-validate",
