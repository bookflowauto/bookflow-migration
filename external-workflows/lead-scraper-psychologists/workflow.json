    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Parse JSON email response per item; carry forward source data\nconst out = [];\nfor (let i = 0; i < $input.all().length; i++) {\n  const ai = $input.all()[i].json;\n  const raw = ai.choices?.[0]?.message?.content\n    || ai.message?.content\n    || ai.text\n    || ai.content\n    || '{}';\n  let emailAddress = '';\n  try {\n    const parsed = JSON.parse(raw.trim());\n    emailAddress = parsed.emailAddress || '';\n  } catch(e) {\n    const m = raw.match(/\"emailAddress\"\\s*:\\s*\"([^\"]*)\"/i);\n    emailAddress = m ? m[1] : '';\n  }\n  const source = $('Parse Validate Result').itemMatching(i).json;\n  out.push({ json: { ...source, emailAddress } });\n}\nreturn out;"
      },
