    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const out = [];\nfor (let i = 0; i < $input.all().length; i++) {\n  const item = $input.all()[i].json;\n  const email = item.emailAddress || '';\n  \n  // Basic email regex validation\n  const emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\n  \n  if (emailRegex.test(email)) {\n    out.push({ json: item });\n  }\n  // else: silently drop invalid emails\n}\nreturn out;"
      },
