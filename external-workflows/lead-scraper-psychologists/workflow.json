    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Extract TRUE/FALSE from OpenAI response per item; carry forward source data\nconst out = [];\nfor (let i = 0; i < $input.all().length; i++) {\n  const ai = $input.all()[i].json;\n  const content = ai.choices?.[0]?.message?.content\n    || ai.message?.content\n    || ai.text\n    || ai.content\n    || '';\n  const isValid = content.trim().toUpperCase().includes('TRUE');\n  const source = $('Strip HTML').itemMatching(i).json;\n  out.push({ json: { ...source, isValid } });\n}\nreturn out;"
      },
