# Postgres (used by n8n's internal DB container)
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=bookflow

# n8n — encrypts stored credentials. CRITICAL: back this up separately.
# Losing it makes every saved workflow credential unrecoverable.
N8N_ENCRYPTION_KEY=change-me-to-a-long-random-string

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # service role JWT — server-only

# Fillout
NEXT_PUBLIC_INTAKE_FORM_URL=https://forms.fillout.com/t/xxx
NEXT_PUBLIC_SCRIBE_FORM_URL=https://forms.fillout.com/t/xxx

# n8n webhook URLs
N8N_RECEIPT_WEBHOOK_URL=https://n8n.bookflow.uk/webhook/receipt-submit

# App
NEXT_PUBLIC_APP_URL=https://app.bookflow.uk

# Stripe (use test keys in dev, live keys in production)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
